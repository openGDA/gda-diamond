<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
						http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- AD hardware -->

	<bean id="camd4_adbase" class="gda.device.detector.areadetector.v17.impl.ADBaseImpl">
		<property name="basePVName" value="BL16I-DI-PHDGN-04:CAM:" />
	</bean>

	<bean id="camd4_ndfile_base" class="gda.device.detector.areadetector.v17.impl.NDPluginBaseImpl">
		<property name="basePVName" value="BL16I-DI-PHDGN-04:TIFF:" />
	</bean>

	<bean id="camd4_ndfile" class="gda.device.detector.areadetector.v17.impl.NDFileImpl">
		<property name="basePVName" value="BL16I-DI-PHDGN-04:TIFF:" />
		<property name="resetToInitialValues" value="false" />
		<property name="pluginBase" ref="camd4_ndfile_base" />
	</bean>

	<bean id="camd4_ndfile_hdf5" class="gda.device.detector.areadetector.v17.impl.NDFileHDF5Impl">
		<property name="basePVName" value="BL16I-DI-PHDGN-04:HDF5:" />
		<property name="file">
			<bean class="gda.device.detector.areadetector.v17.impl.NDFileImpl">
				<property name="basePVName" value="BL16I-DI-PHDGN-04:HDF5:" />
				<property name="resetToInitialValues" value="false" />
				<property name="pluginBase">
					<bean class="gda.device.detector.areadetector.v17.impl.NDPluginBaseImpl">
						<property name="basePVName" value="BL16I-DI-PHDGN-04:HDF5:" />
					</bean>
				</property>
			</bean>
		</property>
		<property name="useSWMR" value="true" />
	</bean>

	<bean id="camd4_ndarray" class="gda.device.detector.areadetector.v17.impl.NDArrayImpl">
		<property name="basePVName" value="BL16I-DI-PHDGN-04:ARR:" />
		<property name="pluginBase">
			<bean class="gda.device.detector.areadetector.v17.impl.NDPluginBaseImpl">
				<property name="basePVName" value="BL16I-DI-PHDGN-04:ARR:" />
				<property name="initialArrayPort" value="D5CAM.CAM" />
			</bean>
		</property>
	</bean>

</beans>
