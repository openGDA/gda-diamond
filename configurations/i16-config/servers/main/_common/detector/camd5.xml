<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
		http://www.springframework.org/schema/beans/spring-beans.xsd"
	profile="NexusScanDataWriter">

	<bean id="camd5" class="gda.device.detector.nexusprocessor.NexusDetectorProcessor" >
		<property name="detector" ref="_camd5"/>
		<property name="processor">
			<bean class="gda.device.detector.nexusprocessor.SwmrHdfDatasetProviderProcessor">
				<property name="detName" value="camd5" />
				<property name="processors">
					<list>
						<bean class="gda.device.detector.nexusprocessor.DatasetPlotter">
							<property name="plotName" ref="camd5_plotName" />
						</bean>
						<ref bean="camd5_rois" />
						<ref bean="camd5_stats" />
					</list>
				</property>
			</bean>
		</property>
	</bean>

	<bean id="camd5_snap" class="gda.device.detector.NXDetectorSnappingDecorator">
		<constructor-arg ref="_camd5_for_snaps" />
		<property name="snappingCollectionStrategy" ref="camd5_nxcollectionstrategy"/>
		<property name="snapperPluginList">
			<list>
				<ref bean="camd5_nxfilewriter_for_snaps" />
			</list>
		</property>
	</bean>

	<bean id="camd5_ad_array_plugin" class="gda.device.detector.nxdetector.plugin.areadetector.ADArrayPlugin">
		<constructor-arg ref="camd5_ndarray"/>
		<property name="enabled" value="False" />
		<property name="writeDataToFile" value="False" />
	</bean>

	<bean id="camd5_plotName" class="java.lang.String" factory-method="valueOf">
		<constructor-arg value="CAMD5"/>
	</bean>

	<bean id="camd5_rois" class="gda.device.detector.nexusprocessor.roistats.RoiStatsProcessor">
		<property name="plotName" ref="camd5_plotName" />
		<property name="statsProcessor" ref="camd5_stats" />
	</bean>

	<bean id="camd5_stats" class="gda.device.detector.nexusprocessor.DatasetStats">
		<property name="enabledStats">
			<list>
				<value>MAX_VAL</value>
				<value>MAX_X</value>
				<value>MAX_Y</value>
				<value>SUM</value>
			</list>
		</property>
		<property name="statNames">
			<map>
				<entry key="MAX_VAL" value="camd5_max_val"/>
				<entry key="MAX_X" value="camd5_max_x"/>
				<entry key="MAX_Y" value="camd5_max_y"/>
				<entry key="SUM" value="camd5_total"/>
			</map>
		</property>
	</bean>

	<!-- NXDetector collection strategies -->

	<bean id="camd5_nxcollectionstrategy" class="gda.device.detector.addetector.triggering.SingleExposureStandard">
		<constructor-arg ref="camd5_adbase" />
		<constructor-arg value="-1" />
	</bean>

	<!-- NXDetector file writers -->

	<bean id="camd5_nxfilewriter_for_scans" class="gda.device.detector.addetector.filewriter.SingleImagePerFileWriter">
		<constructor-arg value="camd5" />
		<property name="ndFile" ref="camd5_ndfile" />
		<property name="keyNameForMetadataPathTemplate" value="camd5_path_template" />
		<property name="waitForFileArrival" value="false" />
		<property name="writeErrorStatusSupported" value="false"/>
		<property name="alwaysPrepare" value="true" />
	</bean>

	<bean id="camd5_nxfilewriter_for_snaps" class="gda.device.detector.addetector.filewriter.SingleImagePerFileWriterWithNumTracker">
		<constructor-arg value="camd5" />
		<property name="ndFile" ref="camd5_ndfile" />
		<property name="numTrackerExtension" value="camd5snaps" />
		<property name="writeErrorStatusSupported" value="false"/>
		<property name="alwaysPrepare" value="true" />
	</bean>

	<bean id="camd5_hdf5_filewriter_for_scans" class="gda.device.detector.addetector.filewriter.MultipleImagesPerHDF5FileWriter">
		<property name="ndFileHDF5" ref="camd5_ndfile_hdf5" />
		<property name="fileNameTemplate" value="$scan$-camd5" />
		<property name="filePathTemplate" value="$datadir$" />
		<property name="fileTemplate" value="%s%s.hdf5" />
		<property name="fileNumberAtScanStart" value="-1" />
		<property name="setFileNameAndNumber" value="true" />
		<property name="blocking" value="false" />
		<property name="setChunking" value="false" />
		<property name="lazyOpen" value="true" />
		<property name="alwaysPrepare" value="true" />
	</bean>

	<!-- NXDetectors -->

	<bean id="_camd5" class="gda.device.detector.NXDetector">
		<property name="name" value="camd5" />
		<property name="collectionStrategy" ref="camd5_nxcollectionstrategy" />
		<property name="additionalPluginList">
			<list>
				<ref bean="camd5_nxfilewriter_for_scans" />
				<ref bean="camd5_hdf5_filewriter_for_scans" />
				<ref bean="camd5_ad_array_plugin" />
			</list>
		</property>
	</bean>

	<bean id="_camd5_for_snaps" class="gda.device.detector.NXDetector">
		<property name="name" value="camd5_for_snaps" />
		<property name="collectionStrategy" ref="camd5_nxcollectionstrategy" />
		<property name="additionalPluginList">
			<list>
				<ref bean="camd5_nxfilewriter_for_snaps" />
			</list>
		</property>
	</bean>

</beans>