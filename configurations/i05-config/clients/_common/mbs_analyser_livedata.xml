<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xmlns:util="http://www.springframework.org/schema/util"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
		http://www.springframework.org/schema/beans/spring-beans.xsd">


	<bean id="AnalyserLiveClient" class="uk.ac.diamond.daq.devices.mbs.MbsAnalyserClientLiveDataDispatcher">
		<property name="analyser" ref="analyser" />
		<property name="arrayPV" value="#{ANALYSER_PV_BASENAME}:ARR:ArrayData" />
		<property name="frameNumberPV" value="#{ANALYSER_PV_BASENAME}:CAM:ArrayCounter_RBV" />
		<property name="acquirePV" value="BL05I-EA-DET-02:CAM:Acquire" />
		<property name="acquisitionModePV" value="#{ANALYSER_PV_BASENAME}:CAM:AcqMode" />
		<property name="numScansPV" value="BL05I-EA-DET-02:CAM:NumScans_RBV"/>
		<property name="progressCounterPV" value="#{ANALYSER_PV_BASENAME}:CAM:CompletedScans_RBV"/>
<!--	this PV can randomly generate 0 values in live mode - do not use it! -->
<!-- 	<property name="progressCounterPV" value="BL05I-EA-DET-02:CAM:CurrentScanNumber_RBV"/> -->
		<property name="numStepsPV" value="#{ANALYSER_PV_BASENAME}:CAM:NumSteps_RBV"/>
		<property name="currentStepPV" value="#{ANALYSER_PV_BASENAME}:CAM:CurrentStepNumber_RBV" />

	</bean>
</beans>