<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
	http://www.springframework.org/schema/beans/spring-beans.xsd">


	<bean id="m4xTransMotor" class="gda.device.motor.DummyMotor">
		<property name="minPosition" value="-1000" />
		<property name="maxPosition" value="1000" />
		<property name="speed" value="90" />
	</bean>

	<bean id="m4yTransMotor" class="gda.device.motor.DummyMotor">
		<property name="minPosition" value="-1000" />
		<property name="maxPosition" value="1000" />
		<property name="speed" value="90" />
	</bean>

	<bean id="m4zTransMotor" class="gda.device.motor.DummyMotor">
		<property name="minPosition" value="-1000" />
		<property name="maxPosition" value="1000" />
		<property name="speed" value="90" />
	</bean>

	<bean id="m4xRotMotor" class="gda.device.motor.DummyMotor">
		<property name="minPosition" value="-1000" />
		<property name="maxPosition" value="1000" />
		<property name="speed" value="90" />
	</bean>

	<bean id="m2yRotMotor" class="gda.device.motor.DummyMotor">
		<property name="minPosition" value="-1000" />
		<property name="maxPosition" value="1000" />
		<property name="speed" value="90" />
	</bean>

	<bean id="m4zRotMotor" class="gda.device.motor.DummyMotor">
		<property name="minPosition" value="-1000" />
		<property name="maxPosition" value="1000" />
		<property name="speed" value="90" />
	</bean>

	<bean id="m4VerticalStage" class="gda.device.motor.DummyMotor">
		<property name="minPosition" value="-1000" />
		<property name="maxPosition" value="1000" />
		<property name="speed" value="90" />
	</bean>

	<!-- Femto -->
	<bean id="m4femto1" class="gda.device.currentamplifier.DummyEpicsCurrAmpSingle"/>
	<bean id="m4femto1gain" class="gda.device.enumpositioner.DummyEnumPositioner">
		<property name="posChangeEventFlag" value="true"/>
		<property name="positions">
			<list>
				<value>10^3 low noise</value>
				<value>10^4 low noise</value>
				<value>10^5 low noise</value>
				<value>10^6 low noise</value>
				<value>10^7 low noise</value>
				<value>10^8 low noise</value>
				<value>10^9 low noise</value>
				<value>10^5 high speed</value>
				<value>10^6 high speed</value>
				<value>10^7 high speed</value>
				<value>10^8 high speed</value>
				<value>10^9 high speed</value>
				<value>10^10 high spd</value>
				<value>10^11 high spd</value>
			</list>
		</property>
	</bean>

	<bean id="m4femto2" class="gda.device.currentamplifier.DummyEpicsCurrAmpSingle"/>

</beans>