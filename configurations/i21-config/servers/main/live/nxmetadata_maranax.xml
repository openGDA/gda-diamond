<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
		http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="maranaxAppender" class="org.eclipse.scanning.device.NexusMetadataAppender" init-method="register">
		<property name="name" value="maranax" />
		<property name="childNodes">
			<list>
				<bean class="org.eclipse.scanning.device.ScalarField">
					<property name="name" value="description"/>
					<property name="value" value="Marana-x - an in vacuum CMOS camera."/>
				</bean>
				<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
					<property name="name" value="manufacturer"/>
					<property name="pvName" value="BL21I-EA-DET-05:CAM:Manufacturer_RBV"/>
				</bean>
				<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
					<property name="name" value="model"/>
					<property name="pvName" value="BL21I-EA-DET-05:CAM:Model_RBV"/>
				</bean>
				<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
					<property name="name" value="serial_number"/>
					<property name="pvName" value="BL21I-EA-DET-05:CAM:SerialNumber"/>
				</bean>
				<bean class="org.eclipse.scanning.device.GroupMetadataNode">
					<property name="name" value="maranax_settings"/>
					<property name="nexusClass" value="NXcollection"/>
					<property name="childNodes">
						<list>
							<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="readout_rate"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:ReadoutRate_RBV"/>
							</bean>
							<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="preamp_gain"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:PreAmpGain_RBV"/>
							</bean>
							<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="shutter_mode"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:ShutterMode_RBV"/>
							</bean>
							<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="data_type"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:DataType_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="color_mode"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:ColorMode_RBV"/>
							</bean>
							<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="frame_rate"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:FrameRate"/>
							</bean>
							<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="overlap_acquisition"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:Overlap_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="noise_filter"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:NoiseFilter_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="pixel_encoding"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:PixelEncoding_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="readout_time"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:ReadoutTime"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="current_temperature"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:Temperature_RBV"/>
								<property name="units" value="°C"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="temperature_setpoint"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:Temperature_RBV"/>
								<property name="units" value="°C"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="transfer_rate"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:TransferRate"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="full_AOI_control"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:FullAOIControl"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="a3_binning"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:A3Binning_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="a3_shutter_mode"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:A3ShutterMode_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="software_trigger"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:SoftwareTrigger"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="sensor_cooling"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:SensorCooling_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="temperature_control"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:TempControl_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="temperature_status"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:TempStatus_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="fan_speed"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:FanSpeed_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="firmware_version"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:FirmwareVersion"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="software_version"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:SoftwareVersion"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="controller_ID"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:ControllerID"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="image_size_y"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:ArraySizeY_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="image_size_x"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:ArraySizeX_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="binning_x"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:BinX_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="binning_y"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:BinY_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="region_start_x"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:MinX_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="region_start_y"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:MinY_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="region_size_x"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:SizeX_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="region_size_y"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:SizeY_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="sensor_size_x"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:MaxSizeX_RBV"/>
							</bean>
	 						<bean class="uk.ac.gda.epics.nexus.device.ProcessingVariableField">
								<property name="name" value="sensor_size_y"/>
								<property name="pvName" value="BL21I-EA-DET-05:CAM:MaxSizeY_RBV"/>
							</bean>
						</list>
					</property>
				</bean>
			</list>
		</property>
	</bean>
</beans>
