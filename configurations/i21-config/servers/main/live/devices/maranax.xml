<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
	http://www.springframework.org/schema/beans/spring-beans.xsd">

<!-- maranax Area Detector EPICS Plugins -->
	<bean id="maranax_adbase" class="gda.spring.V17ADBaseFactoryBean">
		<property name="prefix" value="BL21I-EA-DET-05:CAM:" />
	</bean>
	<bean id="maranax_stats" class="gda.device.detector.areadetector.v17.impl.NDStatsImpl">
		<property name="basePVName" value="BL21I-EA-DET-05:STAT:" />
		<property name="pluginBase">
			<bean class="gda.device.detector.areadetector.v17.impl.NDPluginBaseImpl">
				<property name="basePVName" value="BL21I-EA-DET-05:STAT:" />
				<property name="initialArrayPort" value="MARANAX.trf" />
			</bean>
		</property>
	</bean>
	<bean id="maranax_ndarray" class="gda.device.detector.areadetector.v17.impl.NDArrayImpl">
		<property name="basePVName" value="BL21I-EA-DET-05:ARR:" />
		<property name="pluginBase">
			<bean class="gda.device.detector.areadetector.v17.impl.NDPluginBaseImpl">
				<property name="basePVName" value="BL21I-EA-DET-05:ARR:" />
				<property name="initialArrayPort" value="MARANAX.trf" />
				<property name="initialEnableCallbacks" value="1" />
			</bean>
		</property>
	</bean>
	<bean id="maranax_ndfile" class="gda.device.detector.areadetector.v17.impl.NDFileImpl">
		<property name="basePVName" value="BL21I-EA-DET-05:HDF5:" />
		<property name="pluginBase">
			<bean class="gda.device.detector.areadetector.v17.impl.NDPluginBaseImpl">
				<property name="basePVName" value="BL21I-EA-DET-05:HDF5:" />
				<property name="initialArrayPort" value="MARANAX.trf" />
			</bean>
		</property>
		<property name="initialWriteMode" value="0" />
		<property name="initialNumCapture" value="1" />
		<property name="initialFileName" value="maranax" />
		<property name="initialFileTemplate" value="%s%s.hdf5" />
	</bean>
	<bean id="maranax_hdf5" class="gda.device.detector.areadetector.v17.impl.NDFileHDF5Impl">
		<property name="basePVName" value="BL21I-EA-DET-05:HDF5:" />
		<property name="file" ref="maranax_ndfile" />
	</bean>

	<!-- The Object which get the ROIs from the client over RMI -->
	<bean id="maranax_roi" class="gda.device.detector.nxdetector.roi.LiveStreamROIProvider" />
	<bean class="uk.ac.gda.remoting.server.GdaRmiServiceExporter">
		<property name="serviceName" value="gda/maranaxRoi" />
		<property name="service" ref="maranax_roi" />
		<property name="serviceInterface" value="gda.device.detector.nxdetector.roi.RemoteRectangularROIsProvider" />
	</bean>
	<bean id="maranax_RoiStats1" class="gda.device.detector.nxdetector.plugin.areadetector.ADRoiStatsPairFactory">
		<property name="pluginName" value="maranax_RoiStats1" />
		<property name="baseRoiPVName" value="BL21I-EA-DET-05:ROI1:" />
		<property name="baseStatsPVName" value="BL21I-EA-DET-05:STAT1:" />
		<property name="roiInputNdArrayPort" value="MARANAX.trf" />
		<property name="enabledBasicStats" value="Total" />
		<property name="oneTimeSeriesCollectionPerLine" value="false" />
		<property name="roiProvider">
			<bean class="gda.device.detector.nxdetector.roi.LiveStreamRoiIndexer">
				<property name="liveStreamRoiProvider" ref="maranax_roi" />
				<property name="index" value="0" /> <!-- Zero based indexing i.e. Region 1 = index 0 -->
			</bean>
		</property>
		<property name="legacyTSpvs" value="false"/>
	</bean>
	<bean id="maranax_RoiStats2" class="gda.device.detector.nxdetector.plugin.areadetector.ADRoiStatsPairFactory">
		<property name="pluginName" value="maranax_RoiStats2" />
		<property name="baseRoiPVName" value="BL21I-EA-DET-05:ROI2:" />
		<property name="baseStatsPVName" value="BL21I-EA-DET-05:STAT2:" />
		<property name="roiInputNdArrayPort" value="MARANAX.trf" />
		<property name="enabledBasicStats" value="Total" />
		<property name="oneTimeSeriesCollectionPerLine" value="false" />
		<property name="roiProvider">
			<bean class="gda.device.detector.nxdetector.roi.LiveStreamRoiIndexer">
				<property name="liveStreamRoiProvider" ref="maranax_roi" />
				<property name="index" value="1" /> 
			</bean>
		</property>
		<property name="legacyTSpvs" value="false"/>
	</bean>
	<bean id="maranax_RoiStats3" class="gda.device.detector.nxdetector.plugin.areadetector.ADRoiStatsPairFactory">
		<property name="pluginName" value="maranax_RoiStats3" />
		<property name="baseRoiPVName" value="BL21I-EA-DET-05:ROI3:" />
		<property name="baseStatsPVName" value="BL21I-EA-DET-05:STAT3:" />
		<property name="roiInputNdArrayPort" value="MARANAX.trf" />
		<property name="enabledBasicStats" value="Total" />
		<property name="oneTimeSeriesCollectionPerLine" value="false" />
		<property name="roiProvider">
			<bean class="gda.device.detector.nxdetector.roi.LiveStreamRoiIndexer">
				<property name="liveStreamRoiProvider" ref="maranax_roi" />
				<property name="index" value="2" />
			</bean>
		</property>
		<property name="legacyTSpvs" value="false"/>
	</bean>
	<bean id="maranax_RoiStats4" class="gda.device.detector.nxdetector.plugin.areadetector.ADRoiStatsPairFactory">
		<property name="pluginName" value="maranax_RoiStats4" />
		<property name="baseRoiPVName" value="BL21I-EA-DET-05:ROI4:" />
		<property name="baseStatsPVName" value="BL21I-EA-DET-05:STAT4:" />
		<property name="roiInputNdArrayPort" value="MARANAX.trf" />
		<property name="enabledBasicStats" value="Total" />
		<property name="oneTimeSeriesCollectionPerLine" value="false" />
		<property name="roiProvider">
			<bean class="gda.device.detector.nxdetector.roi.LiveStreamRoiIndexer">
				<property name="liveStreamRoiProvider" ref="maranax_roi" />
				<property name="index" value="3" /> 
			</bean>
		</property>
		<property name="legacyTSpvs" value="false"/>
	</bean>
	<bean id="maranax_RoiStats5" class="gda.device.detector.nxdetector.plugin.areadetector.ADRoiStatsPairFactory">
		<property name="pluginName" value="maranax_RoiStats5" />
		<property name="baseRoiPVName" value="BL21I-EA-DET-05:ROI5:" />
		<property name="baseStatsPVName" value="BL21I-EA-DET-05:STAT5:" />
		<property name="roiInputNdArrayPort" value="MARANAX.trf" />
		<property name="enabledBasicStats" value="Total" />
		<property name="oneTimeSeriesCollectionPerLine" value="false" />
		<property name="roiProvider">
			<bean class="gda.device.detector.nxdetector.roi.LiveStreamRoiIndexer">
				<property name="liveStreamRoiProvider" ref="maranax_roi" />
				<property name="index" value="4" /> 
			</bean>
		</property>
		<property name="legacyTSpvs" value="false"/>
	</bean>
	<bean id="maranax_RoiStats6" class="gda.device.detector.nxdetector.plugin.areadetector.ADRoiStatsPairFactory">
		<property name="pluginName" value="maranax_RoiStats6" />
		<property name="baseRoiPVName" value="BL21I-EA-DET-05:ROI6:" />
		<property name="baseStatsPVName" value="BL21I-EA-DET-05:STAT6:" />
		<property name="roiInputNdArrayPort" value="MARANAX.trf" />
		<property name="enabledBasicStats" value="Total" />
		<property name="oneTimeSeriesCollectionPerLine" value="false" />
		<property name="roiProvider">
			<bean class="gda.device.detector.nxdetector.roi.LiveStreamRoiIndexer">
				<property name="liveStreamRoiProvider" ref="maranax_roi" />
				<property name="index" value="5" /> 
			</bean>
		</property>
		<property name="legacyTSpvs" value="false"/>
	</bean>

</beans>
