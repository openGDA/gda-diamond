<!-- ADDetector used in new scanning -->
	<bean id="maranax_addetector" class="gda.device.detector.addetector.ADDetector">
		<property name="collectionStrategy" ref="maranaxCollectionStrategy"/>
		<property name="adBase" ref="maranax_adbase" />
		<property name="ndFile" ref="maranax_ndfile" /><!-- not used in new scanning -->
		<property name="ndArray" ref="maranax_ndarray" />
		<property name="ndStats" ref="maranax_stats" /><!-- not used in new scanning -->
		<property name="fileWriter" ref="maranaxHdf5Filewriter" /> <!-- not used in new scanning -->
	</bean>

	<bean id="maranaxModel" class="uk.ac.diamond.daq.detectors.addetector.api.AreaDetectorRunnableDeviceModel">
		<property name="name" value="maranax_addetector" />
		<property name="exposureTime" value="0.1" />
	</bean>

	<bean id="maranaxInfo" class="org.eclipse.scanning.api.event.scan.DeviceInformation">
	 	<property name="id" value="org.eclipse.scanning.i21.maranax.DeviceInformation" />
		<property name="label" value="Andor" />
		<property name="description" value="Andor" />
	</bean>

	<bean id="maranax_add" class="uk.ac.diamond.daq.detectors.addetector.AreaDetectorRunnableDevice" init-method="register">
		<property name="name" value="maranax_addetector" />
		<property name="model" ref="maranaxModel" />
		<property name="deviceInformation" ref="maranaxInfo" />
		<property name="activated" value="true" /> <!-- selected automatically on start up -->
	</bean>

</beans>