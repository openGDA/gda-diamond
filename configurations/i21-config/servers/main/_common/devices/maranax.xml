<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
	xsi:schemaLocation="http://www.springframework.org/schema/beans 
	http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="maranaxCollectionStrategy"	class="gda.device.detector.addetector.collectionstrategy.ConfigureAcquireTimeDecorator">
		<property name="restoreAcquireTime" value="true" />
		<property name="decoratee">
			<bean class="gda.device.detector.addetector.collectionstrategy.SingleImageModeDecorator">
				<property name="restoreNumImagesAndImageMode" value="true"/>
				<property name="decoratee">
					<bean class="gda.device.detector.addetector.collectionstrategy.InternalTriggerModeDecorator">
						<property name="restoreTriggerMode" value="true" />
						<property name="decoratee">
							<bean class="gda.device.detector.addetector.collectionstrategy.SoftwareStartStop">
								<property name="adBase" ref="maranax_adbase" />
								<property name="restoreAcquireState" value="true"/>
								<property name="readAcquisitionTime" value="true"/>
							</bean>
						</property>
					</bean>
				</property>
			</bean>
		</property>
	</bean>
	<!-- use EPICS HDF5 plugin to write data to file -->
	<bean id="maranaxHdf5Filewriter" class="gda.device.detector.addetector.filewriter.MultipleImagesPerHDF5FileWriter">
		<property name="ndFileHDF5" ref="maranax_hdf5"/>
		<property name="fileNameTemplate" value="maranax"/>
		<property name="filePathTemplate" value="$datadir$" />
		<property name="fileTemplate" value="%s%s-%d.hdf" />
		<property name="fileNumberAtScanStart" value="-1" />
		<property name="setFileNameAndNumber" value="true" />
		<property name="storeAttr" value="true" />
		<property name="lazyOpen" value="true" />
		<property name="swmrModeEnabled" value="true" />
		<property name="blocking" value="false" />
		<property name="attrByDimSupported" value="true" />
		<property name="attrByDim" value="true" />
		<property name="pathErrorSuppressed" value="true" />
		<property name="alwaysPrepare" value="true"/>
	</bean>
	<!-- used with live stream view -->
 	<bean id="maranax" class="gda.device.detector.NXDetector">
		<property name="name" value="maranax" />
		<property name="collectionStrategy" ref="maranaxCollectionStrategy" />
		<property name="additionalPluginList">
			<list>
				<ref bean="maranax_RoiStats1" />
				<ref bean="maranax_RoiStats2" />
				<ref bean="maranax_RoiStats3" />
				<ref bean="maranax_RoiStats4" />
				<ref bean="maranax_RoiStats5" />
				<ref bean="maranax_RoiStats6" />
				<ref bean="maranaxHdf5Filewriter" />
			</list>
		</property>
	</bean>

