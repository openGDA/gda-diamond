<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- MARANAX Controls in Live Stream Views-->
	<bean id="maranax_time_remaining" class="uk.ac.gda.client.live.stream.controls.custom.widgets.CountDownControl">
		<property name="displayName" value="Time remain"/>
		<property name="group" value="MARANAX" />
		<property name="observable" ref="maranaxCountdown" />
		<property name="textWidth" value="30"/>
		<property name="userUnits" value="s" />
	</bean>
	<bean id="maranax_time_remaining_progress" class="uk.ac.gda.client.live.stream.controls.custom.widgets.CountDownProgressBarControl">
		<property name="displayName" value=""/>
		<property name="group" value="MARANAX" />
		<property name="observable" ref="maranaxCountdownProgress" />
		<property name="barWidth" value="110"/>
	</bean>
	<bean id="maranax_expsure_time_control" class="uk.ac.gda.client.livecontrol.ScannableValueControl">
		<property name="displayName" value="Exposure" />
		<property name="group" value="MARANAX" />
		<property name="scannableName" value="maranaxExposureTime"/>
		<property name="textWidth" value="50"/>
		<property name="userUnits" value="s" />
	</bean>
	<bean id="maranax_acquire_period_control" class="uk.ac.gda.client.livecontrol.ScannableValueControl">
		<property name="displayName" value="Period" />
		<property name="group" value="MARANAX" />
		<property name="scannableName" value="maranaxAcquirePeriod" />
		<property name="textWidth" value="50"/>
		<property name="userUnits" value="s" />
	</bean>
