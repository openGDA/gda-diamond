<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
	
	<bean id="maranax_roi" class="uk.ac.gda.remoting.client.GdaRmiProxyFactoryBean">
		<property name="serviceUrl" value="${gda.rmi.prefix}maranaxRoi" />
		<property name="serviceInterface" value="gda.device.detector.nxdetector.roi.RemoteRectangularROIsProvider" />
		<property name="refreshStubOnConnectFailure" value="true" />
	</bean>

	<import resource="../_common/maranax_controls.xml"/>
	<bean id="maranax" class="uk.ac.gda.client.live.stream.view.CameraConfiguration">
		<property name="displayName" value="MARANAX" />
		<property name="url" value="http://bl21i-di-serv-01.diamond.ac.uk:8099/MARANAX.mjpg.mjpg" />
		<property name="arrayPv" value="BL21I-EA-DET-05:ARR" />
		<property name="roiProvider" ref="maranax_roi" />
		<property name="calibratedAxesProvider" ref="displayPixelNumberOnAxes"/>
		<property name="topUi">
			<bean class="uk.ac.gda.client.live.stream.controls.custom.widgets.CustomCameraLiveControls">
				<property name="liveControls">
					<list>
						<ref bean="maranax_expsure_time_control" />
						<ref bean="maranax_acquire_period_control"/>
						<ref bean="maranax_time_remaining" />
						<ref bean="maranax_time_remaining_progress" />
					</list>				
				</property>
				<property name="cameraState">
					<bean id="maranaxCameraState" class="uk.ac.gda.client.live.stream.controls.camera.state.EpicsCameraState">
						<property name="pvName" value="BL21I-EA-DET-03:CAM:Acquire"/>
						<property name="stateVariableName" value="i21.maranax.live.stream.active"/>
					</bean>
				</property>
			</bean>
		</property>
		<property name="bottomUi">
			<bean class="uk.ac.gda.beamline.i21.views.RixsSpectrumView">
				<property name="xSizeHint" value="200"/>
				<property name="ySizeHint" value="350"/>
			</bean>
		</property>
	</bean>

</beans>
