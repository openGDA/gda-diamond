<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="xphiPilatusScanModel" class="org.eclipse.scanning.api.device.models.MalcolmModel">
		<property name="name" value="BL15I-ML-SCAN-07"/>
		<property name="exposureTime" value="1"/>
	</bean>

	<bean id="xphiPilatusScanInfo" class="org.eclipse.scanning.api.event.scan.DeviceInformation">
		<property name="label" value="Pilatus dxdkphi"/>
		<property name="description" value="Hardware mapping scanning using the XPHI stages"/>
		<property name="shownByDefault" value="true"/>
	</bean>

	<bean id="xphiPilatusScanDevice" class="org.eclipse.scanning.malcolm.core.MalcolmDevice" init-method="register">
		<property name="name" value="BL15I-ML-SCAN-07"/>
		<property name="model" ref="xphiPilatusScanModel"/>
		<property name="deviceInformation" ref="xphiPilatusScanInfo"/>
	</bean>
</beans>

