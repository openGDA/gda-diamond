<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
	http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="smx_motor" class="gda.device.motor.DummyMotor">
		<property name="unitString" value="mm" />
	</bean>

	<bean id="smy_motor" class="gda.device.motor.DummyMotor">
		<property name="unitString" value="mm" />
	</bean>

	<bean id="smz_motor" class="gda.device.motor.DummyMotor">
		<property name="unitString" value="mm" />
	</bean>

	<bean id="smdefocus_motor" class="gda.device.motor.DummyMotor">
		<property name="unitString" value="mm" />
	</bean>

	<bean id="smpolar_motor" class="gda.device.motor.DummyMotor">
		<property name="unitString" value="deg" />
		<property name="speed" value="90" />
	</bean>

	<bean id="smazimuth_motor" class="gda.device.motor.DummyMotor">
		<property name="unitString" value="deg" />
		<property name="speed" value="90" />
	</bean>

	<!-- Simulated IOC motors -->
	<bean id="smy_motor_sim" class="gda.device.motor.EpicsMotor">
		<property name="pvName" value="ws667-MO-SIM-01:M2" />
	</bean>

	<bean id="smy_sim" class="gda.device.scannable.ScannableMotor">
		<property name="motor" ref="smy_motor_sim" />
		<property name="initialUserUnits" value="micron" />
		<property name="hardwareUnitString" value="mm" />
		<property name="lowerGdaLimits" value="-7000" />
		<property name="upperGdaLimits" value="6500" />
	</bean>

</beans>